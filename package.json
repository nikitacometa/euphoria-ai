{
    "name": "euphoria-ai",
    "version": "1.0.0",
    "description": "AI-powered journaling companion for Telegram: voice/video transcription, AI insights, and chat over your journal history",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nikitacometa/euphoria-ai.git"
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "typecheck": "tsc",
        "build": "tsc -p tsconfig.build.json && cp -R src/admin/views dist/admin/",
        "dev": "tsx watch src/main.ts",
        "start": "node dist/main.js",
        "admin": "tsx src/admin/text-editor.ts",
        "backfill-embeddings": "tsx scripts/backfill-embeddings.ts",
        "lint": "eslint src evals",
        "format": "prettier --write src",
        "test": "vitest run",
        "eval": "tsx evals/run-evals.ts"
    },
    "dependencies": {
        "chalk": "^5.4.1",
        "dotenv": "^16.4.7",
        "ejs": "^3.1.9",
        "express": "^4.18.2",
        "grammy": "^1.35.0",
        "mongoose": "^8.12.1",
        "openai": "^4.86.2",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/ejs": "^3.1.5",
        "@types/express": "^4.17.21",
        "@types/node": "^22.13.10",
        "@vitest/coverage-v8": "4.1.10",
        "eslint": "9.39.5",
        "prettier": "3.9.5",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "8.64.0",
        "vitest": "4.1.10"
    }
}
